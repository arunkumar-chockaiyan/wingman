// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(uuid())
  email     String        @unique
  name      String
  createdAt DateTime      @default(now())
  sessions  CallSession[]
}

model CallSession {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  title           String
  startTime       DateTime         @default(now())
  endTime         DateTime?
  fullTranscript  String?          @db.Text
  summary         String?          @db.Text

  // Sales-rep authored context — persisted live as the rep types
  repNotes        String?          @db.Text
  repLinks        String?          @db.Text
  repInstructions String?          @db.Text

  recommendations Recommendation[]
  callSummary     CallSummary?

  @@index([userId])
  @@index([startTime])
}

model CallSummary {
  id            String        @id @default(uuid())
  callSessionId String        @unique
  session       CallSession   @relation(fields: [callSessionId], references: [id])

  // Structured outcome of the call
  outcome       String?       @db.Text       // e.g. "Follow-up scheduled", "Demo booked"
  sentiment     CallSentiment @default(NEUTRAL)

  // JSON arrays stored as Json columns
  keyTopics     Json?                         // string[]
  actionItems   Json?                         // string[]

  // Free-form notes added post-call
  notes         String?       @db.Text

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([callSessionId])
}

enum CallSentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

model Recommendation {
  id             String      @id @default(uuid())
  callSessionId  String
  session        CallSession @relation(fields: [callSessionId], references: [id])
  content        String      @db.Text
  
  // High-level category for filtering (Sales, News, Q&A)
  category       String
  
  // The specific agent that generated this
  agentId        String      
  
  contextSnippet String?     @db.Text
  feedbackStatus FeedbackStatus @default(NONE)
  createdAt      DateTime    @default(now())

  @@index([callSessionId])
  @@index([category])
  @@index([createdAt]) // Added for chronological insight retrieval
}

enum FeedbackStatus {
  NONE
  LIKED
  DISLIKED
}
